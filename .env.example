# AlgoWeaver AI 环境配置示例
# 复制此文件为 .env 并填入实际值

# 应用基础配置
APP_NAME=AlgoWeaver AI
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# 服务器配置
HOST=0.0.0.0
PORT=8000
RELOAD=true

# LLM API 配置 (必需)
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# LangSmith 追踪配置 (可选)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=algoweaver-ai
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING=true

# Redis 缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# 安全配置 (必需)
SECRET_KEY=your_secret_key_here_please_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# CORS 配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true

# Python 沙箱配置
SANDBOX_TIMEOUT=30
SANDBOX_MEMORY_LIMIT=128m
SANDBOX_CPU_QUOTA=50000
SANDBOX_MAX_PROCESSES=50

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/algoweaver.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# 性能配置
MAX_CONCURRENT_TASKS=10
TASK_TIMEOUT=300
RATE_LIMIT_PER_HOUR=100